# ============================================================
# PolyBot - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Rellena cada valor con tus claves reales
# 3. NUNCA compartas este archivo con nadie
# ============================================================

# --- Anthropic (Claude) ---
# Obtén tu API key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- Polymarket CLOB API ---
# Se generan desde la app de Polymarket o el CLI
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=

# --- Wallet Polygon ---
# IMPORTANTE: Esta es tu clave privada. NUNCA la compartas.
# Puedes crear una wallet nueva solo para el bot.
POLYGON_WALLET_PRIVATE_KEY=0x...

# --- Telegram (opcional, para notificaciones) ---
# Crea un bot con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
