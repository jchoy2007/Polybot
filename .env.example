# ============================================================
# PolyBot - Variables de Entorno
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo como .env  (cp .env.example .env)
#   2. Rellena cada valor con tus claves reales
#   3. NUNCA compartas este archivo con nadie
#   4. chmod 600 .env  (solo tu usuario lo lee)
# ============================================================

# --- Wallet Polygon (REQUERIDO) ---
# IMPORTANTE: Esta es tu clave privada de MetaMask.
# Cómo exportarla: MetaMask → tres puntos → Account details → Show
# private key. NUNCA la compartas.
# Recomendación: crea una wallet nueva solo para el bot.
POLYGON_WALLET_PRIVATE_KEY=0x...

# --- Polymarket Funder Address / Proxy (REQUERIDO) ---
# Es la dirección PROXY donde vive el dinero en Polymarket (NO la EOA
# de MetaMask). Se ve en polymarket.com → menú wallet → "Proxy".
POLYMARKET_FUNDER_ADDRESS=0x...

# --- Tipo de firma Polymarket v2 (REQUERIDO) ---
# Browser proxy con funder = 2 (la opción correcta tras la migración v2).
SIGNATURE_TYPE=2

# --- RPC Polygon (REQUERIDO) ---
# Opción gratis/lenta:    https://polygon-rpc.com
# Opción rápida (Alchemy, gratis hasta 300M reqs/mes):
#   https://alchemy.com → Create App → Polygon Mainnet → copy HTTPS URL
ALCHEMY_RPC_URL=https://polygon-rpc.com

# --- Telegram (REQUERIDO para notificaciones) ---
# Crea un bot con @BotFather → /newbot → guarda el token.
# chat_id: abrir https://api.telegram.org/bot<TOKEN>/getUpdates tras
# enviarle /start a tu bot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Anthropic / Claude (OPCIONAL) ---
# Solo si quieres activar 🔍 MARKET SCANNER (sports/esports IA).
# Obtén tu API key en: https://console.anthropic.com/
# Si lo dejas vacío, solo opera el módulo 📈 STOCK TRADER.
ANTHROPIC_API_KEY=

# --- Polymarket CLOB API (LEGACY — opcional) ---
# v2 deriva la API key automáticamente con la private key, NO se usan.
# Se dejan por compatibilidad histórica.
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
